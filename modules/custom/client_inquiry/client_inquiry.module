<?php

use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Session\AccountInterface;

/**
 * Implements hook_form_FORM_ID_alter().
 */
function client_inquiry_form_node_client_inquiry_edit_form_alter(
  &$form,
  FormStateInterface $form_state,
  $form_id
) {

  $current_user = \Drupal::currentUser();

  // Sirf Manager role ke liye.
  if (!$current_user->hasRole('manager')) {
    return;
  }

  $fields = [
    'title',
    'field_client_id',
    'field_client_name',
    'field_client_contact',
    'field_inquiry_category',
    'field_event_date',
    'field_event_time',
    'field_order_amount',
    'body',
  ];

  foreach ($fields as $field) {
    if (isset($form[$field])) {
      $form[$field]['#disabled'] = TRUE;
    }
  }
}