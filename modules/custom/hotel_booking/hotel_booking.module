<?php

use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Form\FormStateInterface;

/**
 * Implements hook_entity_presave().
 */
function hotel_booking_entity_presave(EntityInterface $entity) {

  // ==============================
  // 🏨 HOTEL ID GENERATION
  // ==============================
  if ($entity->getEntityTypeId() === 'node' && $entity->bundle() === 'hotels') {

    // Edit case → ID change ना हो
    if (!$entity->isNew()) {
      $original = $entity->original;

      if ($original && !$original->get('field_hotel_id')->isEmpty()) {
        $entity->set(
          'field_hotel_id',
          $original->get('field_hotel_id')->value
        );
      }
      return;
    }

    // New hotel → generate HT001
    $last_id = \Drupal::database()
      ->query("
        SELECT MAX(CAST(SUBSTRING(field_hotel_id_value, 3) AS UNSIGNED))
        FROM {node__field_hotel_id}
      ")
      ->fetchField();

    $next_id = $last_id ? $last_id + 1 : 1;

    $hotel_id = 'HT' . str_pad($next_id, 3, '0', STR_PAD_LEFT);

    $entity->set('field_hotel_id', $hotel_id);
  }

  // ==============================
  // 🏨 HOTEL BOOKING ID GENERATION
  // ==============================
  if ($entity->getEntityTypeId() === 'node' && $entity->bundle() === 'hotel_booking') {

    // Edit case → ID change ना हो
    if (!$entity->isNew()) {
      $original = $entity->original;

      if ($original && !$original->get('field_hotel_booking_id')->isEmpty()) {
        $entity->set(
          'field_hotel_booking_id',
          $original->get('field_hotel_booking_id')->value
        );
      }
      return;
    }

    // 📅 Current Year
    $year = date('Y');

    // 🔍 Last booking number (same year)
    $last_id = \Drupal::database()
      ->query("
        SELECT MAX(CAST(SUBSTRING(field_hotel_booking_id_value, 10) AS UNSIGNED))
        FROM {node__field_hotel_booking_id}
        WHERE field_hotel_booking_id_value LIKE :pattern
      ", [
        ':pattern' => 'HTL-' . $year . '-%'
      ])
      ->fetchField();

    $next_id = $last_id ? $last_id + 1 : 1;

    // 🧾 Final Booking ID
    $booking_id = 'HTL-' . $year . '-' . str_pad($next_id, 4, '0', STR_PAD_LEFT);

    $entity->set('field_hotel_booking_id', $booking_id);
  }
}

/**
 * Implements hook_form_alter().
 */
function hotel_booking_form_alter(&$form, FormStateInterface $form_state, $form_id) {

  // Sirf hotel form pe apply karo
  if ($form_id == 'node_hotels_form' || $form_id == 'node_hotels_edit_form') {

    if (isset($form['field_hotel_id'])) {
      // 🔒 Disable field (read-only)
      $form['field_hotel_id']['widget'][0]['value']['#disabled'] = TRUE;
    }
  }

  if ($form_id == 'node_hotel_booking_form' || $form_id == 'node_hotel_booking_edit_form') {

    if (isset($form['field_hotel_booking_id'])) {
      $form['field_hotel_booking_id']['widget'][0]['value']['#disabled'] = TRUE;
    }
  }
}